generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Cliente {
  id       String   @id @db.VarChar(12)
  nome     String   @db.VarChar(255)
  telefone String   @db.VarChar(30)
  endereco Endereco[]
  pedido   Pedido[]

  @@map("cliente")
}

model Endereco {
  id          String   @id @db.VarChar(12)
  cliente_id  String   @db.VarChar(12)
  logradouro  String   @db.VarChar(255)
  numero      String   @db.VarChar(10)
  bairro      String   @db.VarChar(100)
  cidade      String?  @db.VarChar(100)
  cep         String?  @db.VarChar(8)
  complemento String?  @db.VarChar(255)
  ativo       Boolean  @default(true)
  cliente     Cliente  @relation(fields: [cliente_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_endereco_cliente")
  pedido      Pedido[]

  @@index([cliente_id], map: "fk_endereco_cliente")
  @@map("endereco")
}

model Ingrediente {
  id                  String                      @id @db.VarChar(12)
  nome                String                      @db.VarChar(100)
  quantidade_atual    Decimal?                    @db.Decimal(10, 3)
  unidade_medida      ingrediente_unidade_medida? @default(un)
  estoque_minimo      Decimal?                    @db.Decimal(10, 3)
  preco_unitario      Decimal?                    @db.Decimal(10, 2)
  produto_ingrediente ProdutoIngrediente[]

  @@map("ingrediente")
}

model ItemPedido {
  id                    String   @id @db.VarChar(12)
  pedido_id             String   @db.VarChar(12)
  produto_id            String?  @db.VarChar(12)

  // Campo de Snapshot (momento da venda)
  nome_snapshot         String   @db.VarChar(100)
  descricao_snapshot    String?  @db.VarChar(255)
  quantidade            Int
  preco_unitario        Decimal  @db.Decimal(10, 2)
  subtotal              Decimal? @db.Decimal(10, 2)

  pedido                Pedido   @relation(fields: [pedido_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_pedido_item_pedido")
  produto               Produto?  @relation(fields: [produto_id], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "fk_produto_item_pedido")

  @@index([pedido_id], map: "fk_pedido_item_pedido")
  @@index([produto_id], map: "fk_produto_item_pedido")
  @@map("itens_pedido")
}

model Pedido {
  id                  String        @id @db.VarChar(12)

  // RELAÇÕES
  cliente_id          String?       @db.VarChar(12)
  endereco_id         String?       @db.VarChar(12)
  pizzaiolo_id        String?       @db.VarChar(12)
  entregador_id       String?       @db.VarChar(12)

  cliente             Cliente?      @relation(fields: [cliente_id], references: [id], onDelete: SetNull)
  endereco            Endereco?     @relation(fields: [endereco_id], references: [id], onDelete: SetNull)
  pizzaiolo           Usuario?      @relation("pedido_pizzaiolo", fields: [pizzaiolo_id], references: [id])
  entregador          Usuario?      @relation("pedido_entregador", fields: [entregador_id], references: [id])

  // SNAPSHOT CLIENTE
  cliente_nome        String        @db.VarChar(255)
  cliente_telefone    String        @db.VarChar(30)

  // SNAPSHOT ENDEREÇO
  entrega_logradouro  String        @db.VarChar(255)
  entrega_numero      String        @db.VarChar(10)
  entrega_bairro      String        @db.VarChar(100)
  entrega_cidade      String?       @db.VarChar(100)
  entrega_cep         String?       @db.VarChar(8)
  entrega_complemento String?       @db.VarChar(255)

  // PEDIDO
  status              pedido_status @default(pendente)
  //subtotal            Decimal       @db.Decimal(10, 2)
  taxa_entrega        Decimal       @default(0) @db.Decimal(10, 2)
  valor_total         Decimal       @db.Decimal(10, 2)
  observacoes         String?       @db.VarChar(500)
  data_pedido         DateTime      @default(now()) @db.Timestamp(0)

  // ITENS
  itens_pedido        ItemPedido[]

  @@index([cliente_id])
  @@index([endereco_id]) // <- Índice adicionado para performance
  @@index([pizzaiolo_id])
  @@index([entregador_id])
  @@map("pedido")
}

model Produto {
  id                  String               @id @db.VarChar(12)
  nome                String               @db.VarChar(100)
  descricao           String               @db.VarChar(255)
  preco_unitario      Decimal              @db.Decimal(10, 2)
  categoria           produto_categoria    @default(pizza)
  imagem_url          String?              @db.VarChar(255)
  ativo               Boolean              @default(true)
  itens_pedido        ItemPedido[]
  produto_ingrediente ProdutoIngrediente[]

  @@map("produto")
}

model ProdutoIngrediente {
  id             String      @id @db.VarChar(12)
  produto_id     String      @db.VarChar(12)
  ingrediente_id String      @db.VarChar(12)
  quantidade     Decimal     @db.Decimal(10, 3)
  ingrediente    Ingrediente @relation(fields: [ingrediente_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_ingrediente_prod_ing")
  produto        Produto     @relation(fields: [produto_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_produto_prod_ing")

  @@index([ingrediente_id], map: "fk_ingrediente_prod_ing")
  @@index([produto_id], map: "fk_produto_prod_ing")
  @@map("produtos_ingredientes")
}

model Usuario {
  id                      String        @id @db.VarChar(12)
  nome                    String        @db.VarChar(255)
  email                   String        @unique(map: "email") @db.VarChar(255)
  senha                   String        @db.VarChar(255)
  telefone                String?       @db.VarChar(30)
  cargo                   usuario_cargo 
  data_criacao            DateTime      @default(now()) @db.Timestamp(0)
  ativo                   Boolean       @default(true)

  pedidos_como_entregador Pedido[]      @relation("pedido_entregador")
  pedidos_como_pizzaiolo  Pedido[]      @relation("pedido_pizzaiolo")

  @@map("usuario")
}

enum ingrediente_unidade_medida {
  un
  kg
  g
  ml
  L
}

enum produto_categoria {
  pizza
  bebida
  sobremesa
}

enum usuario_cargo {
  gestor
  pizzaiolo
  entregador
}

enum pedido_status {
  pendente
  preparo
  pronto
  em_rota   @map("em rota")
  entregue
  cancelado
}